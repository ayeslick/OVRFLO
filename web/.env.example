# OVRFLO web configuration — six knobs, three profiles, zero code changes between environments.
#
# Chain id is locked to mainnet because the OVRFLO contract hardcodes mainnet-only
# protocol dependencies (Sablier, Pendle oracle). Local and dev environments must
# run against an anvil fork of mainnet with chain id 1.
NEXT_PUBLIC_CHAIN_ID=1

# Deployed OVRFLOFactory address for the target environment.
NEXT_PUBLIC_OVRFLO_FACTORY=0x0000000000000000000000000000000000000000

# Reown / WalletConnect AppKit project id (required for the wallet modal).
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id

# RPC endpoint. Omit to use wagmi's default public transport.
#   local:   http://127.0.0.1:8545
#   dev:     https://virtual.mainnet.rpc.tenderly.co/<id>
#   mainnet: https://mainnet.infura.io/v3/<key> (or similar paid provider)
# NEXT_PUBLIC_RPC_URL=

# Price API base URL used for underlying-token USD quotes. Defaults to CoinGecko's
# public /api/v3 endpoints. Override with a CoinGecko Pro URL or an internal proxy.
# NEXT_PUBLIC_PRICE_API_URL=https://api.coingecko.com/api/v3

# Sablier Envio GraphQL endpoint. Defaults to Sablier's hosted indexer (used by
# devnet + mainnet). For the local loop, bootstrap:local points this at the
# vendored indexer under tools/envio/ (exposed on :8080 via Envio's CLI).
# NEXT_PUBLIC_SABLIER_INDEXER_URL=https://indexer.hyperindex.xyz/53b7e25/v1/graphql

# ── Profiles ──────────────────────────────────────────────────────────────────
# Local  (anvil fork):
#   NEXT_PUBLIC_CHAIN_ID=1
#   NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545
#   NEXT_PUBLIC_OVRFLO_FACTORY=<address printed by seed-local.sh>
#   NEXT_PUBLIC_SABLIER_INDEXER_URL=http://localhost:8080/v1/graphql
#
# Dev    (tenderly / staging):
#   NEXT_PUBLIC_CHAIN_ID=1
#   NEXT_PUBLIC_RPC_URL=<tenderly virtual testnet url>
#   NEXT_PUBLIC_OVRFLO_FACTORY=<address of staging factory>
#   NEXT_PUBLIC_SABLIER_INDEXER_URL=<leave unset to use hosted default>
#
# Mainnet:
#   NEXT_PUBLIC_CHAIN_ID=1
#   NEXT_PUBLIC_RPC_URL=<paid mainnet rpc>
#   NEXT_PUBLIC_OVRFLO_FACTORY=<mainnet factory>
#   NEXT_PUBLIC_SABLIER_INDEXER_URL=<leave unset to use hosted default>
