# RPC that the Envio indexer connects to. Defaults to the host machine's
# anvil instance launched by `bootstrap:local`. On Docker Desktop,
# host.docker.internal resolves automatically. On Linux, either:
#   a) run `docker compose` with `--add-host=host.docker.internal:host-gateway`, or
#   b) set ENVIO_RPC_URL=http://172.17.0.1:8545  (default docker0 bridge)
ENVIO_RPC_URL=http://host.docker.internal:8545
